#include <iostream>
using namespace std;

class Book {
private:
    string title;
    string author;
    int copies;

public:
    Book(string t, string a, int c) {
        title = t;
        author = a;
        copies = c;
    }

    void issueBook() {
        if (copies > 0) {
            copies--;
            cout << "Book Issued Successfully.\n";
        }
        else {
            cout << "Book Not Available.\n";
        }
    }

    void displayBook() {
        cout << "\nTitle: " << title;
        cout << "\nAuthor: " << author;
        cout << "\nAvailable Copies: " << copies << endl;
    }
};

int main() {
    Book b1("C++ Programming", "Bjarne Stroustrup", 3);

    b1.displayBook();
    b1.issueBook();
    b1.displayBook();

    return 0;
}
